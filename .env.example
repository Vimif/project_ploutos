# ========================================
# BROKER SELECTION
# ========================================
# Broker principal: 'etoro' (défaut) ou 'alpaca'
BROKER=etoro

# ========================================
# eToro API (https://api-portal.etoro.com/)
# ========================================
ETORO_PUBLIC_API_KEY=your_public_api_key_here
ETORO_USER_KEY=your_user_key_here
# Legacy aliases still supported by the codebase:
ETORO_SUBSCRIPTION_KEY=your_public_api_key_here
ETORO_API_KEY=your_user_key_here
# Legacy username/password login is no longer used by the current client.
ETORO_USERNAME=
ETORO_PASSWORD=
# ========================================
# Alpaca API (fallback)
# ========================================
# Paper Trading
ALPACA_PAPER_API_KEY=your_paper_api_key
ALPACA_PAPER_SECRET_KEY=your_paper_secret_key

# Live Trading
ALPACA_LIVE_API_KEY=your_live_api_key
ALPACA_LIVE_SECRET_KEY=your_live_secret_key

# ========================================
# Database (PostgreSQL - optionnel)
# ========================================
DB_HOST=localhost
DB_NAME=ploutos
DB_USER=ploutos
DB_PASSWORD=your_db_password

# ========================================
# Free macro data
# ========================================
# Free FRED API key (recommended for stable macro data)
FRED_API_KEY=your_fred_api_key_here

# Optional macro provider override: auto, fred, yahoo
MACRO_DATA_PROVIDER=auto

# ========================================
# Dashboard
# ========================================
ALLOWED_CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:3000
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000
